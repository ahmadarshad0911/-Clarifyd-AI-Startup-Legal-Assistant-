# =============================================================
# Clarifyd / AI Contract Risk Analyzer — backend env template
# Copy this to backend/.env and fill in real values.
# NEVER commit backend/.env to version control.
# =============================================================

# --- Core ---
ENVIRONMENT=development
DEBUG=True
LOG_LEVEL=INFO
PROJECT_NAME=AI Contract Risk Analyzer

# --- File upload ---
MAX_UPLOAD_FILE_SIZE=26214400          # 25 MiB
ALLOWED_FILE_TYPES=.pdf,.docx

# --- Database ---
# Dev default is SQLite local file. Postgres URL works too:
#   postgresql+asyncpg://user:pass@localhost:5432/clarifyd
DATABASE_URL=sqlite+aiosqlite:///./clarifyd.db
DB_ECHO=False
DB_CREATE_ALL_ON_STARTUP=True

# --- CORS ---
CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

# --- JWT (local email/password + OAuth-issued tokens) ---
JWT_SECRET=change-me-please-this-is-not-secure
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MINUTES=60

# --- Rate limiting (in-memory) ---
RATE_LIMIT_LOGIN_PER_MIN=60
RATE_LIMIT_ANALYZE_PER_MIN=10

# --- Review routing ---
REVIEW_CONFIDENCE_THRESHOLD=0.7
REVIEW_AUTO_ROUTE_SEVERITIES=high,critical

# --- Export / retention ---
EXPORT_DIR=./exports
RETENTION_DAYS=365

# =============================================================
# Reasoning model — Kimi K2.6 via NVIDIA NIM
# Get an API key: https://build.nvidia.com/
# =============================================================
REASONING_PROVIDER=kimi
REASONING_BASE_URL=https://integrate.api.nvidia.com/v1
REASONING_API_KEY=
# Kimi K2.6 on NIM occasionally hangs on the free tier.
# Llama 3.3 70B is the working fallback.
REASONING_MODEL=meta/llama-3.3-70b-instruct
REASONING_MODEL_FALLBACK=meta/llama-3.3-70b-instruct
REASONING_TIMEOUT_SECONDS=60
REASONING_MAX_RETRIES=1

# =============================================================
# OAuth — Google + Facebook
# Leave a value blank to disable that provider (button → 503).
# =============================================================

# --- Google ---
# Console:  https://console.cloud.google.com/apis/credentials
# Redirect: http://localhost:8000/auth/oauth/google/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# --- Facebook ---
# Console:  https://developers.facebook.com/apps
# Redirect: http://localhost:8000/auth/oauth/facebook/callback
FACEBOOK_OAUTH_CLIENT_ID=
FACEBOOK_OAUTH_CLIENT_SECRET=

# --- Microsoft (legacy; UI button removed but route still works) ---
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_TENANT=common

# --- OAuth callback URLs (change only if you change ports) ---
OAUTH_BACKEND_BASE_URL=http://localhost:8000
OAUTH_FRONTEND_CALLBACK_URL=http://localhost:3000/oauth/callback

# =============================================================
# Frontend env (frontend/.env.local) — for reference only
# =============================================================
# NEXT_PUBLIC_API_URL=http://localhost:8000
