# Environment Variables - Copy to .env and fill in your values
# NEVER commit the .env file to version control!

# =====================
# GENERAL CONFIGURATION
# =====================
ENVIRONMENT=development
DEBUG=True
LOG_LEVEL=INFO
PROJECT_NAME=AI Contract Risk Analyzer

# =====================
# DATABASE CONFIGURATION
# =====================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/contract_analyzer
DATABASE_ECHO=False
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40
DATABASE_POOL_TIMEOUT=30

# =====================
# REDIS CONFIGURATION
# =====================
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=
REDIS_DB=0

# =====================
# ELASTICSEARCH CONFIGURATION
# =====================
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_SCHEME=http
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=

# =====================
# AWS/S3 CONFIGURATION
# =====================
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=contract-analyzer-prod
S3_UPLOAD_FOLDER=contracts/

# =====================
# OPENAI API CONFIGURATION
# =====================
OPENAI_API_KEY=sk-... # Your OpenAI API key
OPENAI_MODEL=gpt-4o
OPENAI_MODEL_FALLBACK=gpt-4o-mini
OPENAI_API_TIMEOUT=30
OPENAI_MAX_RETRIES=3

# =====================
# JWT & AUTHENTICATION
# =====================
SECRET_KEY=your-super-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
REFRESH_TOKEN_EXPIRATION_DAYS=7

# =====================
# FRONTEND CONFIGURATION
# =====================
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=AI Contract Risk Analyzer
NEXT_PUBLIC_APP_ENVIRONMENT=development

# =====================
# AUTH CONFIGURATION (Optional - for SAML/OAuth)
# =====================
AUTH_PROVIDER=local  # Options: local, google, okta, azure
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OKTA_CLIENT_ID=
OKTA_CLIENT_SECRET=
OKTA_DOMAIN=

# =====================
# EMAIL CONFIGURATION
# =====================
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USERNAME=apikey
SMTP_PASSWORD=SG.your-sendgrid-key
SENDER_EMAIL=noreply@example.com
SENDER_NAME=AI Contract Risk Analyzer

# =====================
# CELERY CONFIGURATION
# =====================
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TASK_SERIALIZER=json
CELERY_ACCEPT_CONTENT=json
CELERY_RESULT_SERIALIZER=json
CELERY_TIMEZONE=UTC

# =====================
# MONITORING & LOGGING
# =====================
SENTRY_DSN=
DATADOG_API_KEY=
DATADOG_APP_KEY=

# =====================
# CORS & SECURITY
# =====================
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
CORS_ALLOW_CREDENTIALS=True
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOW_HEADERS=*

# =====================
# RATE LIMITING
# =====================
RATE_LIMIT_REQUESTS=1000
RATE_LIMIT_PERIOD=60  # seconds

# =====================
# FILE UPLOAD
# =====================
MAX_UPLOAD_FILE_SIZE=104857600  # 100MB in bytes
ALLOWED_FILE_TYPES=.pdf,.docx,.txt
MAX_BATCH_SIZE=1000

# =====================
# AI PIPELINE CONFIGURATION
# =====================
CONFIDENCE_THRESHOLD=0.50  # Min confidence to show finding (0-1)
MULTI_PASS_VALIDATION_ENABLED=True
HALLUCINATION_DETECTION_ENABLED=True
CRITICAL_CLAUSE_TYPES=Liability,Indemnification,IP,Confidentiality

# =====================
# COMPLIANCE & LEGAL
# =====================
COMPLIANCE_MODE=strict  # strict, standard, permissive
DEFAULT_JURISDICTION=US
ENFORCE_AUDIT_LOGGING=True

# =====================
# PAGINATION & LIMITS
# =====================
DEFAULT_PAGE_SIZE=50
MAX_PAGE_SIZE=500
MAX_SEARCH_RESULTS=10000

# =====================
# FEATURE FLAGS
# =====================
FEATURE_TEAM_COLLABORATION=True
FEATURE_BATCH_PROCESSING=True
FEATURE_API_ACCESS=False  # Enable for enterprise
FEATURE_WEBHOOKS=False
FEATURE_BENCHMARKING=False

# =====================
# TIME ZONES
# =====================
TIMEZONE=UTC

# =====================
# EXTERNAL SERVICE CREDENTIALS
# =====================
# Add any additional service credentials here
# e.g., for integrations with Slack, Zapier, etc.
SLACK_webhook_URL=
