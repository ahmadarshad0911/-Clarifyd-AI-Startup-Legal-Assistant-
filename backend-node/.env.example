# Vercel Postgres
DATABASE_URL=postgres://USER:PASS@HOST/DB?sslmode=require

# Vercel Blob
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx

# NVIDIA NIM (Kimi K2)
NIM_API_URL=https://integrate.api.nvidia.com/v1/chat/completions
NIM_API_KEY=nvapi-xxx
NIM_MODEL_ID=moonshotai/kimi-k2-instruct

# Auth.js
AUTH_SECRET=run-openssl-rand-base64-32
AUTH_URL=http://localhost:3001
AUTH_TRUST_HOST=true

# Resend (magic-link email)
RESEND_API_KEY=re_xxx
RESEND_FROM=auth@clarifyd.dev

# Vault key for OAuth-token encryption (AES-GCM)
VAULT_KEY=base64-32-bytes

# Rate limit default (free tier)
FREE_TIER_SCAN_LIMIT=3

# Upstash Redis (token bucket rate limit + caches)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Inngest (background jobs)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Cron auth (Vercel Cron / internal)
CRON_SECRET=

# Slack OAuth
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=

# Gmail / Google OAuth (Drive shares scope)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/integrations/gmail/callback

# Notion OAuth
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=

# Facebook OAuth (Login + Graph)
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# Public base URL (for OAuth callbacks + magic-link redirects)
APP_URL=http://localhost:3001
