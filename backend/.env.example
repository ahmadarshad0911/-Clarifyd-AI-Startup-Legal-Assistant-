ENVIRONMENT=development
DEBUG=True
LOG_LEVEL=INFO
PROJECT_NAME=AI Contract Risk Analyzer
MAX_UPLOAD_FILE_SIZE=26214400
ALLOWED_FILE_TYPES=.pdf,.docx

# === Reasoning model: Kimi (Moonshot AI) ===
# Paste your Kimi API key in REASONING_API_KEY below.
# Get one at https://platform.moonshot.ai/console/api-keys (intl) or https://platform.moonshot.cn (CN).
REASONING_PROVIDER=kimi
REASONING_BASE_URL=https://api.moonshot.ai/v1
REASONING_API_KEY=
REASONING_MODEL=moonshot-v1-32k
REASONING_MODEL_FALLBACK=moonshot-v1-8k
REASONING_TIMEOUT_SECONDS=30
REASONING_MAX_RETRIES=3
